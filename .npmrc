# Repo has React 19 throughout, but several otherwise-fine dependencies still
# declare React 15/16/18 peer ranges:
#   - vite-react-ssg's bundled react-helmet-async (peer: ^16|17|18)
#   - react-open-doodles (peer: ^15|16, ships static SVG components only)
# Without legacy-peer-deps, npm install fails in CI (Cloudflare Pages build).
# Local installs already use this flag; pinning it here keeps CI consistent.
legacy-peer-deps=true
